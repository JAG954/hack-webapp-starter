# Copy to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.
#
# Required for the chat + agent at /chat and the drawer's "Ask agent" link.
# Get a key at https://www.subconscious.dev/platform
SUBCONSCIOUS_API_KEY=

# Optional: override the dashboard's live-data endpoint. Defaults to
# http://localhost:8000/dashboard-summary (the path the partner backend
# will expose). When unset and unreachable, the dashboard silently falls
# back to mock data.
# NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:8000/dashboard-summary
